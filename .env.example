# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# PostgreSQL
POSTGRES_USER=billbot
POSTGRES_PASSWORD=billbot
POSTGRES_DB=billbot
DATABASE_URL=postgresql+asyncpg://billbot:billbot@postgres:5432/billbot

# Bot settings
# Timezone for due-date calculations and scheduler. Default: UTC+3 (Etc/GMT-3)
BOT_TIMEZONE=Etc/GMT-3

# Product rule: due_day is capped at 28 (no end-of-month handling in v1)
